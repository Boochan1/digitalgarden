---
layout: layouts/base.njk
title: Projects
permalink: /projects/
---

<section class="page-header" style="text-align: center; margin-bottom: 3rem;">
    <h1 style="font-size: 2.5rem; font-weight: 800;">My Projects</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 0.5rem;">Tools, scripts, and things I've built.</p>
</section>

<section class="project-grid">
    {% for project in collections.project | reverse %}
        <a href="{{ project.url }}" class="project-card">
            <h2>{{ project.data.title | default(project.fileSlug) }}</h2>
            <p>{{ project.data.description }}</p>
            <span class="project-date">{{ project.date | readableDate }}</span>
        </a>
    {% else %}
        <p style="text-align: center; color: var(--text-muted);">No projects published yet. Check back soon.</p>
    {% endfor %}
</section>
