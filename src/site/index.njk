---
layout: layouts/base.njk
title: Home
---

{% set latestThought = collections.thoughts | last %}

<section class="hero-thought">
    <div class="thought-content">
        {% if latestThought %}
            {{ latestThought.content | safe }}
            
            <p class="thought-date">{{ latestThought.date | readableDate }}</p>
        {% else %}
            <h1>Publish a note with the tag "thoughts" in Obsidian to see it here.</h1>
        {% endif %}
    </div>
</section>

<section class="reaction-zone" id="reaction-zone" data-slug="{{ latestThought.fileSlug }}">
    <div class="input-container">
        <div class="input-icon">💭</div>
        <input type="text" id="reaction-input" class="reaction-input" placeholder="React to this thought...">
        <button id="send-btn" class="send-btn">Send</button>
    </div>

    <div id="reactions-container" class="recent-reactions">
        </div>
</section>

<section class="archive-action">
    <a href="/archive" class="btn-archive">View Archive of Daily Thoughts</a>
</section>
